includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    paths:
        - app/
        - bootstrap/app.php
        - config/
        - database/
        - routes/

    level: 7

    ignoreErrors:
        - '#Static method Native\\Desktop\\Facades\\System::print\(\) invoked with 3 parameters#'
        - '#Static method Native\\Desktop\\Facades\\System::printToPDF\(\) invoked with 2 parameters#'
